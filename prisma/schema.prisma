generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== المستخدمين ====================
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("viewer")
  permissions   Json?     // { dashboard: true, customers: true, inbox: true, ... }
  loginAttempts Int       @default(0)
  lockUntil     DateTime?
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ==================== المنصات ====================
model Platform {
  id           String    @id @default(uuid())
  name         String    @unique
  displayName  String
  isConnected  Boolean   @default(false)
  accessToken  String?
  refreshToken String?
  apiKey       String?
  apiSecret    String?
  supplierId   String?
  metadata     Json?
  tokenExpiry  DateTime?
  lastSync     DateTime?
  syncStatus   String    @default("idle") // idle, syncing, error
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ==================== العملاء ====================
model Customer {
  id           String    @id @default(uuid())
  name         String
  email        String?
  phone        String?
  source       String // shopify, trendyol, instagram, facebook, whatsapp, gmail
  segment      String    @default("new") // vip, active, idle, lost, new
  rfmScore     Int?
  totalOrders  Int       @default(0)
  totalSpent   Float     @default(0)
  averageOrder Float     @default(0)
  lastOrderAt  DateTime?
  tags         String[]
  notes        String?
  metadata     Json? // بيانات إضافية من المنصات
  platformIds  Json? // { shopify: "123", trendyol: "456" }
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]
  messages     Message[]

  @@unique([email, source])
  @@index([segment])
  @@index([source])
  @@index([lastOrderAt])
}

// ==================== الطلبات ====================
model Order {
  id              String   @id @default(uuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  platform        String // shopify, trendyol
  platformOrderId String
  status          String // pending, processing, shipped, delivered, cancelled, refunded
  subtotal        Float
  shipping        Float    @default(0)
  discount        Float    @default(0)
  total           Float
  currency        String   @default("USD")
  items           Json // [{ productId, name, variant, quantity, price }]
  shippingAddress Json?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([platform, platformOrderId])
  @@index([customerId])
  @@index([platform])
  @@index([status])
  @@index([createdAt])
}

// ==================== المنتجات ====================
model Product {
  id          String           @id @default(uuid())
  name        String
  description String?
  category    String?
  brand       String?
  images      String[]
  platforms   Json // { shopify: { id, url }, trendyol: { id, url } }
  variants    ProductVariant[]
  tags        String[]
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([isActive])
}

model ProductVariant {
  id             String   @id @default(uuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  sku            String?  @unique
  size           String?
  color          String?
  price          Float
  compareAtPrice Float?
  costPrice      Float? // سعر التكلفة لحساب هامش الربح
  currency       String   @default("USD")
  stock          Int      @default(0)
  lowStockAlert  Int      @default(5)
  platformIds    Json? // { shopify_variant_id, trendyol_barcode }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
  @@index([stock])
}

// ==================== الرسائل (Unified Inbox) ====================
model Message {
  id            String    @id @default(uuid())
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  platform      String // instagram, facebook, whatsapp, gmail
  platformMsgId String?
  direction     String // inbound, outbound
  senderName    String?
  senderHandle  String? // @username أو email أو phone
  content       String
  mediaUrls     String[]
  intent        String? // inquiry, complaint, purchase, support, general
  sentiment     String? // positive, neutral, negative
  status        String    @default("unread") // unread, read, replied, archived
  agentResponse String? // الرد المقترح من الإيجنت
  agentApproved Boolean   @default(false)
  repliedAt     DateTime?
  threadId      String? // لربط الرسائل بنفس المحادثة
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([platform])
  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([threadId])
}

// ==================== المحتوى ====================
model Content {
  id             String    @id @default(uuid())
  platform       String // instagram, facebook
  type           String // post, story, reel, carousel
  caption        String?
  hashtags       String[]
  mediaUrls      String[]
  canvaDesignId  String?
  scheduledAt    DateTime?
  publishedAt    DateTime?
  status         String    @default("draft") // draft, scheduled, publishing, published, failed
  platformPostId String?
  engagement     Json? // { likes, comments, shares, saves, reach, impressions }
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([platform])
  @@index([status])
  @@index([scheduledAt])
}

// ==================== الإعلانات ====================
model AdCampaign {
  id             String      @id @default(uuid())
  platform       String // meta, trendyol
  platformCampId String
  name           String
  status         String // active, paused, ended
  objective      String? // awareness, traffic, conversions
  budget         Float
  budgetType     String      @default("daily") // daily, lifetime
  currency       String      @default("USD")
  startDate      DateTime
  endDate        DateTime?
  insights       AdInsight[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([platform, platformCampId])
  @@index([status])
}

model AdInsight {
  id          String     @id @default(uuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id])
  date        DateTime   @db.Date
  impressions Int        @default(0)
  clicks      Int        @default(0)
  spend       Float      @default(0)
  conversions Int        @default(0)
  revenue     Float      @default(0)
  ctr         Float? // Click-Through Rate
  cpc         Float? // Cost Per Click
  cpa         Float? // Cost Per Acquisition
  roas        Float? // Return on Ad Spend
  createdAt   DateTime   @default(now())

  @@unique([campaignId, date])
  @@index([date])
}

// ==================== المالية ====================
model Revenue {
  id        String   @id @default(uuid())
  platform  String // shopify, trendyol
  orderId   String?
  amount    Float
  currency  String   @default("USD")
  date      DateTime @db.Date
  category  String? // product_sales, shipping_fees, other
  createdAt DateTime @default(now())

  @@index([platform])
  @@index([date])
}

model Expense {
  id           String   @id @default(uuid())
  category     String // ads, shipping, inventory, salary, subscription, rent, other
  platform     String? // meta, shopify, trendyol, other
  amount       Float
  currency     String   @default("USD")
  description  String?
  date         DateTime @db.Date
  isRecurring  Boolean  @default(false)
  recurringDay Int? // يوم الشهر للمصاريف المتكررة
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([date])
  @@index([date, category])
}

// ==================== الإيجنتات ====================
model AgentConfig {
  id              String     @id @default(uuid())
  name            String     @unique // master, crm, content, ads, finance, inventory, inbox
  displayName     String
  description     String
  isActive        Boolean    @default(true)
  automationLevel String     @default("semi") // full, semi, manual
  settings        Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  logs            AgentLog[]
}

model AgentLog {
  id        String      @id @default(uuid())
  agentId   String
  agent     AgentConfig @relation(fields: [agentId], references: [id])
  action    String
  details   String?
  result    Json?
  status    String // success, error, warning, info
  duration  Int? // بالميلي ثانية
  createdAt DateTime    @default(now())

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
}

// ==================== التنبيهات ====================
model Alert {
  id        String   @id @default(uuid())
  agentName String
  type      String // info, warning, error, success
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  actionUrl String? // رابط للإجراء المطلوب
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([agentName])
  @@index([createdAt])
}

// ==================== حملات الرسائل ====================
model MessageCampaign {
  id             String    @id @default(uuid())
  name           String
  platform       String // whatsapp, instagram, email
  targetSegment  String // vip, active, idle, lost, all, custom
  customFilter   Json? // فلتر مخصص
  templateId     String? // لواتساب — ID القالب المعتمد من Meta
  content        String
  mediaUrl       String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  status         String    @default("draft") // draft, scheduled, sending, sent, failed
  totalTargeted  Int       @default(0)
  totalSent      Int       @default(0)
  totalDelivered Int       @default(0)
  totalRead      Int       @default(0)
  totalClicked   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

// ==================== إعدادات النظام ====================
model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}
